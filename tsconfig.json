{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,
		"paths": {
			"picola": ["./src/core/index.ts"],
			"picola/svelte": ["./src/svelte/index.ts"],
			"picola/picola.css": ["./src/picola.css"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.svelte",
		"playground/**/*.ts",
		"playground/**/*.svelte",
		"e2e/**/*.ts",
		"e2e/**/*.svelte",
		"vite.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"bench/size-dist",
		"bench-dist",
		"playground-dist"
	]
}
